# ===== Cartoon Plants — environment config =====
# Скопируй в .env и заполни. .env НИКОГДА не коммитится (в .gitignore).

# --- OpenRouter (агенты: идея → выбор → сценарий → фактчек → промпты) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5-nano
# Для фактчекинга лучше более сильная модель (точность советов):
OPENROUTER_MODEL_FACTCHECK=

# --- PoYo AI (картинки: gpt-image-2 / gpt-image-2-edit) ---
POYO_API_KEY=
POYO_BASE=https://api.poyo.ai
POYO_IMAGE_SIZE=9:16
POYO_IMAGE_RESOLUTION=1K
POYO_IMAGE_QUALITY=low

# --- VeoNonStop (видео: image-to-video) ---
VEONONSTOP_API_KEY=
VEONONSTOP_BASE=https://veononstop.org/api/v1
# kie.ai — видео-бэкенд (veo3_lite, 720p). Если ключ задан, видео идёт через kie (рекомендуется).
KIE_API_KEY=

# --- Google Drive (референсы + финальные видео) ---
# OAuth desktop app credentials (из Google Cloud Console). tokens.json получается через setup-google.js
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_TOKENS_PATH=tokens.json

# --- Telegram (опционально: уведомления) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Runtime ---
# Сколько сцен генерить (по умолчанию 5)
SCENE_COUNT=5
NODE_ENV=production
